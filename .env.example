# LLM provider
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# Backend
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=sqlite:///./support_sop_agent.db

# RAG
VECTOR_STORE_PATH=./chroma
RAG_TOP_K=4
RAG_EMBEDDING_PROVIDER=hash
RAG_VECTOR_STORE_BACKEND=sqlite
RAG_VECTOR_STORE_PATH=./data/sop_vectors.sqlite3
RAG_VECTOR_WEIGHT=0.7
RAG_KEYWORD_WEIGHT=0.3

# Agent workflow
AGENT_TOOL_MAX_ATTEMPTS=3
AGENT_MAX_STEPS=10

# Memory
MEMORY_STORE_PATH=./data/memories.sqlite3
MEMORY_RETRIEVAL_TOP_K=5
MEMORY_MIN_CONFIDENCE=0.5

# Review rules
HIGH_AMOUNT_THRESHOLD=500
LOW_CONFIDENCE_THRESHOLD=0.7
